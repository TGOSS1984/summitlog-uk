# -------------------------------------------------------
# SummitLog — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# -------------------------------------------------------

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True

# Comma-separated — no spaces around commas
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Local dev (SQLite — simple, no setup needed):
# Leave blank to use default SQLite at backend/db.sqlite3
DATABASE_URL=sqlite:///path/to/your/db.sqlite3
#
# Production (Render / Railway — paste the connection string from your dashboard):
# DATABASE_URL=postgres://user:password@host:5432/dbname

# CORS & CSRF — comma-separated, no trailing slash
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# -------------------------------------------------------
# Cloudflare R2 media storage
# Leave blank to use local media storage (development)
# Fill in all four to enable R2 (production)
# -------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=your-account-id-here
AWS_ACCESS_KEY_ID=your-r2-access-key-id-here
AWS_SECRET_ACCESS_KEY=your-r2-secret-access-key-here
AWS_STORAGE_BUCKET_NAME=summitlog-media